# Local PostgreSQL connection used by Drizzle (drizzle.config.ts / db/index.ts)
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://traxjob:CHANGE_ME@localhost:5432/traxjob

# Backend server (server/)
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Gmail SMTP for password-reset email (optional in dev — if unset, the reset
# link is logged to the server console instead of emailed). Use a Gmail
# App Password (requires 2FA on the account), not your normal password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_FROM=
